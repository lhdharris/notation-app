{
  "name": "notation-app",
  "version": "1.3.0",
  "description": "A minimalist markdown editor with a collapsible workspace panel.",
  "homepage": "https://github.com/lhdharris/notation-app",
  "main": "main.js",
  "author": {
    "name": "Louis Harris",
    "email": "lhd.louis.harris@gmail.com"
  },
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --linux rpm",
    "dist:deb": "electron-builder --linux deb",
    "dist:mac": "electron-builder --mac dmg",
    "dist:win": "electron-builder --win nsis",
    "dist:all-on-mac": "electron-builder --mac dmg --win nsis --linux deb"
  },
  "devDependencies": {
    "electron": "^42.4.0",
    "electron-builder": "^26.8.1",
    "katex": "^0.17.0"
  },
  "build": {
    "appId": "com.github.lhdharris.notation-app",
    "productName": "Notation",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "updater.js",
      "renderer/**",
      "assets/**"
    ],
    "fileAssociations": [
      {
        "ext": "md",
        "name": "Markdown Document",
        "description": "Markdown text document",
        "mimeType": "text/markdown",
        "role": "Editor",
        "rank": "Default"
      },
      {
        "ext": "markdown",
        "name": "Markdown Document",
        "description": "Markdown text document",
        "mimeType": "text/markdown",
        "role": "Editor"
      }
    ],
    "linux": {
      "target": [
        "rpm",
        "deb"
      ],
      "category": "Office",
      "executableName": "notation-app",
      "icon": "build/icons",
      "maintainer": "lhd.louis.harris@gmail.com"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.productivity",
      "icon": "build/icons/1024x1024.png",
      "identity": null
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icons/256x256.png"
    }
  }
}
